# Sample environment variables for cufc-next

# MongoDB
MONGO_URI=

# Auth0 (v4 - @auth0/nextjs-auth0)
# Generate AUTH0_SECRET at: https://generate-secret.vercel.app/32
AUTH0_SECRET=
AUTH0_DOMAIN=
APP_BASE_URL=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=

# Square
SQUARE_ACCESS_TOKEN=
SQUARE_SIGNATURE_KEY=
SQUARE_RETAIL_LOCATION_ID=

# App Config (optional - defaults to America/New_York)
NEXT_PUBLIC_APP_TIMEZONE=